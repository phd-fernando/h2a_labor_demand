# helper: weighted quantiles + mean, returns named list
wstats <- function(x, w) {
  q <- Hmisc::wtd.quantile(x, weights = w, probs = c(0.25, 0.5, 0.75), na.rm = TRUE)
  list(p25 = q[1], med = q[2], p75 = q[3], mn = weighted.mean(x, w, na.rm = TRUE))
}

# helper: add reference lines + staggered labels for one set of stats
# weighted=TRUE uses dark colours; weighted=FALSE uses lighter grey-toned colours
# vjust_base: weighted labels sit at top (1.2); unweighted pushed down (8+)
add_reflines <- function(p, stats, weighted = TRUE, line_color = "#1a1a1a") {
  if (weighted) {
    col_val <- line_color
    cols   <- c(p25 = col_val, med = col_val, mn = col_val, p75 = col_val)
    ltys   <- c(p25 = "dashed", med = "solid", mn = "dotted", p75 = "dashed")
    vjusts <- c(p25 = 1.2,      med = 1.2,     mn = 5.0,      p75 = 1.2)
    lwd    <- 0.7
  } else {
    cols   <- c(p25 = "#AAAAAA", med = "#AAAAAA", mn = "#AAAAAA", p75 = "#AAAAAA")
    ltys   <- c(p25 = "dashed",  med = "solid",   mn = "dotted",  p75 = "dashed")
    vjusts <- c(p25 = 8.5,       med = 8.5,       mn = 12.0,      p75 = 8.5)
    lwd    <- 0.5
  }
  labs <- c(p25 = paste0("P25\n",  round(stats$p25, 1)),
            med = paste0("Med\n",  round(stats$med, 1)),
            mn  = paste0("Mean\n", round(stats$mn,  1)),
            p75 = paste0("P75\n",  round(stats$p75, 1)))
  for (nm in names(cols)) {
    p <- p +
      geom_vline(xintercept = stats[[nm]], color = cols[nm],
                 linetype = ltys[nm], linewidth = lwd) +
      ggplot2::annotate("label", x = stats[[nm]], y = Inf,
               label = labs[nm], vjust = vjusts[nm], hjust = -0.1,
               size = 3.2, color = cols[nm], family = font,
               fill = "white", label.size = 0, alpha = 0.85)
  }
  p
}

# unweighted stats helper (plain quantile + mean)
ustats <- function(x) {
  q <- quantile(x, probs = c(0.25, 0.5, 0.75), na.rm = TRUE)
  list(p25 = q[1], med = q[2], p75 = q[3], mn = mean(x, na.rm = TRUE))
}

# --- contract length ---
st_len   <- wstats(hist_length$length_weeks, hist_length$workers_req)
st_len_u <- ustats(hist_length$length_weeks)

p_len <- ggplot(hist_length, aes(x = length_weeks)) +
  # unweighted: share of total job orders per bin
  geom_histogram(aes(y = after_stat(count / sum(count))),
                 binwidth = 2, fill = "#888888", alpha = 0.65,
                 color = "white", linewidth = 0.2) +
  # worker-weighted: share of total workers per bin
  geom_histogram(aes(y = after_stat(count / sum(count)), weight = workers_req),
                 binwidth = 2, fill = econ_cols[1], alpha = 0.75,
                 color = "white", linewidth = 0.2) +
  scale_x_continuous(breaks = seq(0, 78, by = 4),
                     labels = function(x) paste0(x, "w")) +
  scale_y_continuous(labels = scales::percent,
                     expand = expansion(mult = c(0, 0.08))) +
  labs(
    title    = "Distribution of H-2A Contract Length",
    subtitle = "Blue = worker-weighted; gray = unweighted (job orders); share of total; bin = 2 weeks",
    x = "Contract length (weeks)", y = "Relative frequency",
    caption  = paste0(
      "Source: U.S. Department of Labor, H-2A Disclosure Data.\n",
      "Note: The spike at 52 weeks reflects sheepherder contracts (NAICS 112410), which are explicitly ",
      "authorized for year-round H-2A employment under DOL regulations (20 C.F.R. \u00a7655.100). ",
      "These are concentrated in Idaho, Utah, Colorado, Wyoming, and Nevada."
    )
  ) +
  hist_theme

p_len <- add_reflines(p_len, st_len,   weighted = TRUE, line_color = econ_cols[1])
p_len <- add_reflines(p_len, st_len_u, weighted = FALSE)
ggsave(paste0(mydir, "\\processed\\images\\hist_contractlength.png"),
       plot = p_len, width = 2000, height = 2000, units = "px", dpi = 200)


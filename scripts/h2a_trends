# ------------------------------------------------------------------------------
# Figure 2. Active spells over time
# ------------------------------------------------------------------------------
df_active <- df.jobs %>%
  filter(!is.na(startDate), !is.na(endDate)) %>%
  select(startDate, endDate, naic_code)

timeline <- seq(min(df_active$startDate), max(df_active$endDate), by = "day")

counts <- data.frame(date = timeline) %>%
  rowwise() %>%
  mutate(
    active1 = sum(df_active$startDate <= date & df_active$endDate >= date),
    active2 = sum(df_active$startDate <= date & df_active$endDate >= date &
                    substr(df_active$naic_code, 1, 3) == "111"),
    active3 = sum(df_active$startDate <= date & df_active$endDate >= date &
                    substr(df_active$naic_code, 1, 3) == "112")
  ) %>%
  ungroup()

ggplot(counts) +
  geom_line(aes(date, active1), linewidth = 1) +
  geom_line(aes(date, active2), linewidth = 1) +
  labs(
    x     = NULL,
    y     = "Active spells",
    title = "Active spells over time"
  ) +
  theme_minimal()


STOP


# ##############################################################################

# unit of observation is county x year
zip2fips <- read_delim(
  paste0(mydir, "\\raw\\data\\ZIP-COUNTY-FIPS_2017-06.csv"),
  col_select = c(jobPostcode = 1, fips = 4)
)

df.h2a <- df.jobs %>%
  mutate(jobPostcode = coalesce(worksite_postal_code, employer_postal_code)) %>%
  merge(zip2fips, by = "jobPostcode") %>%
  group_by(fips, year = format(startDate, "%Y")) %>%
  dplyr::summarise(
    n          = n(),
    workers_req = sum(workers_req, na.rm = TRUE),
    fte        = sum(fte,          na.rm = TRUE),
    fte_crop   = sum(fte_crop,     na.rm = TRUE)
  ) %>%
  ungroup()


dates <- seq(
  from = as.Date("2008-01-01"),
  to   = as.Date("2025-09-01"),
  by   = "month"
)


# plot geographical distribution certified workers
for (date in dates) {
  p <- plot_usmap(
    data    = df.h2a %>%
                filter(as.Date(startDate) <= date & as.Date(endDate) >= date) %>%
                mutate(fte = log(1 + fte)),
    values  = "fte",
    regions = "county",
    exclude = c("AK", "HI"),
    color   = "#EFF5F5"
  ) +
    scale_fill_continuous(
      low      = "white",
      high     = my_col[1],
      na.value = "white",
      name     = "Number of visas \nrequested (log+1)",
      label    = scales::comma,
      limits   = c(0, 10)
    ) +
    theme(plot.subtitle = element_text(size = 18, family = font)) +
    theme(legend.position = "right") +
    labs(title = paste("H-2A visa requests active in", format(as.Date(date), "%B %Y")))

  ggsave(
    paste0(mydir, "\\processed\\fig\\countycertifiedworkers_", date, ".png"),
    plot  = p,
    width = 2000, height = 2000, units = "px"
  )
}



# set seed to my phone number
set.seed(2028349824)

# smallest number in this version of R
e =.Machine$double.xmin

# maximum size of datasets in this script
N=Inf

# set directory
mydir = "C:/Users/Fer/UF Dropbox/Fernando Jose Brito-Gonzalez/Fernando_Brito_Dissertation/h2a_labor/h2a_labor_demand"

setwd(mydir)

# load functions and packages for this script
source(paste0(mydir,"/scripts/myfuns_h2ajson.R"))

# set directory
ddir <- paste0(mydir, "/raw/data/disclosure/")

# keep df.jobs pointing to the legacy version for downstream compatibility
df.jobs <- read.csv(paste0(ddir, "h2a_combined.csv"), stringsAsFactors = FALSE)

# ------------------------------------------------------------------------------
# Data prep: parse dates, compute duration, fte, fte_crop
# ------------------------------------------------------------------------------
df.jobs <- df.jobs %>%
  mutate(
    startDate  = as.Date(sub("T.*$", "", requsted_start_date)),
    endDate    = as.Date(sub("T.*$", "", requsted_end_date)),
    length     = as.numeric(endDate - startDate),
    length     = ifelse(length > 0 & length <= 548, length, NA_real_), # drop impossible durations (>18 months or negative)
    # FY2008-2010: hours column absent in DOL disclosure → fall back to 40
    hoursWeek  = ifelse(is.na(as.numeric(basic_number_of_hours)), 40,
                        as.numeric(basic_number_of_hours)),
    hoursWeek  = ifelse(hoursWeek > 0 & hoursWeek <= 80, hoursWeek, NA_real_), # drop impossible hours
    workers    = as.numeric(nbr_workers_certified),
    # FY2008-2010, FY2013-2014: requested workers absent → fall back to certified
    workers_req= coalesce(as.numeric(nbr_workers_requested),
                          as.numeric(nbr_workers_certified)),
    fte        = (length / 7 * hoursWeek) / (52 * 40) * workers_req,
    fte_crop   = ifelse(
      substr(naic_code, 1, 3) == "111" | substr(naic_code, 1, 4) == "1151",
      fte, 0
    )
  )


# ------------------------------------------------------------------------------
# Figure 1. Monthly trends: visa requests, FTE, FTE crop  (Economist style)
# ------------------------------------------------------------------------------
econ_bg   <- "#D5E4EB"                          # Economist chart background
econ_cols <- c("#006BA2", "#C0392B", "#3EBCD2") # blue, red, teal

# pre-compute so we can extract the scale factor before plotting
plot_data <- df.jobs %>%
  filter(!is.na(startDate),
         startDate >= as.Date("2005-01-01"),
         startDate <= as.Date("2024-12-31")) %>%
  group_by(ym = as.Date(format(startDate, "%Y-%m-01"))) %>%
  dplyr::summarise(
    fte_crop       = sum(fte_crop,                             na.rm = TRUE),
    fte_total      = sum(fte,                                  na.rm = TRUE),
    workers_crop   = sum(ifelse(substr(naic_code,1,3)=="111"|substr(naic_code,1,4)=="1151",
                                workers_req, 0),               na.rm = TRUE),
    workers_total  = sum(workers_req,                          na.rm = TRUE),
    n_with_naics   = sum(!is.na(naic_code) & naic_code != "",  na.rm = TRUE)
  ) %>%
  mutate(
    # crop FTE share of total FTE (from 2018 onward)
    share_fte      = ifelse(n_with_naics > 0 & fte_total > 0 & ym >= as.Date("2018-01-01"),
                            fte_crop / fte_total * 100, NA_real_),
    # FTE as % of raw certified workers (fte intensity ratio, full history)
    fte_ratio      = ifelse(workers_total > 0,
                            fte_total / workers_total * 100, NA_real_),
    # 12-month trailing moving averages
    fte_ma12          = zoo::rollmean(fte_total,     k = 12, fill = NA, align = "right"),
    fte_crop_ma12     = zoo::rollmean(fte_crop,      k = 12, fill = NA, align = "right"),
    workers_ma12      = zoo::rollmean(workers_total, k = 12, fill = NA, align = "right"),
    share_fte_ma12    = zoo::rollmeanr(share_fte,    k = 12, fill = NA),
    fte_ratio_ma12    = zoo::rollmeanr(fte_ratio,    k = 12, fill = NA),
    # suppress crop MA before 2018 (workers_ma12 starts as early as data allows)
    fte_crop_ma12  = ifelse(ym >= as.Date("2018-01-01"), fte_crop_ma12, NA_real_)
  )

# label points: one per year (December)
label_blue <- plot_data %>% filter(!is.na(fte_ratio_ma12),  format(ym, "%m") == "12")
label_red  <- plot_data %>% filter(!is.na(share_fte_ma12),  format(ym, "%m") == "12")

ggplot(plot_data, aes(x = ym)) +
  # raw monthly points (faint, behind MA lines)
  geom_point(aes(y = fte_total),     size = 0.6, color = econ_cols[1], alpha = 0.12, na.rm = TRUE) +
  geom_point(data = plot_data %>% filter(ym >= as.Date("2018-01-01")),
             aes(y = fte_crop),      size = 0.6, color = econ_cols[2], alpha = 0.12, na.rm = TRUE) +
  geom_point(aes(y = workers_total), size = 0.6, color = "black",       alpha = 0.12, na.rm = TRUE) +
  # 12-month MA lines
  geom_line(aes(y = fte_ma12),      linewidth = 0.8, color = econ_cols[1], na.rm = TRUE) +
  geom_line(aes(y = fte_crop_ma12), linewidth = 0.8, color = econ_cols[2], na.rm = TRUE) +
  geom_line(aes(y = workers_ma12),  linewidth = 0.8, color = "black",       na.rm = TRUE) +
  # blue line: H-2A FTE as % of certified workers (FTE intensity)
  geom_text(
    data  = label_blue,
    aes(x = ym, y = fte_ma12, label = paste0(round(fte_ratio_ma12), "%")),
    color = econ_cols[1], size = 2.8, vjust = -0.7, family = font, na.rm = TRUE
  ) +
  # red line: crop FTE as % of total H-2A FTE
  geom_text(
    data  = label_red,
    aes(x = ym, y = fte_crop_ma12, label = paste0(round(share_fte_ma12), "%")),
    color = econ_cols[2], size = 2.8, vjust = -0.7, family = font, na.rm = TRUE
  ) +

  coord_cartesian(ylim = c(0, 35000)) +
  scale_y_continuous(
    labels = label_number(scale = 1/1000, suffix = "K"),
    expand = expansion(mult = c(0, 0.02))
  ) +
  scale_x_date(
    date_breaks = "1 year",
    date_labels = "%Y",
    expand      = expansion(mult = c(0.01, 0.01))
  ) +

  labs(
    title    = "Growth of the H-2A Program",
    subtitle = "Total FTE (blue, label = FTE/workers %), crop FTE (red, label = crop FTE/total FTE %), certified workers (black); 12-month moving average",
    caption  = "Source: U.S. Department of Labor, H-2A Disclosure Data"
  ) +

  theme_minimal(base_family = font) +
  theme(
    # backgrounds
    panel.background    = element_rect(fill = econ_bg,  color = NA),
    plot.background     = element_rect(fill = econ_bg,  color = NA),
    legend.background   = element_rect(fill = econ_bg,  color = NA),
    legend.key          = element_rect(fill = econ_bg,  color = NA),

    # gridlines: horizontal white lines only
    panel.grid.major.y  = element_line(color = "white", linewidth = 0.5),
    panel.grid.major.x  = element_blank(),
    panel.grid.minor    = element_blank(),

    # axes
    axis.ticks          = element_blank(),
    axis.title          = element_blank(),
    axis.text.x         = element_text(size = 9, color = "#333333",   family = font),
    axis.text.y         = element_text(size = 9, color = econ_cols[1], family = font),

    # legend: horizontal, top-left
    legend.position     = "top",
    legend.justification = "left",
    legend.direction    = "horizontal",
    legend.text         = element_text(size = 9,  color = "#333333", family = font),

    # title / subtitle / caption
    plot.title          = element_text(size = 13, face = "bold",   hjust = 0,
                                       color = "#1a1a1a", family = font,
                                       margin = margin(b = 4)),
    plot.title.position = "plot",
    plot.subtitle       = element_text(size = 9,  color = "#555555", hjust = 0,
                                       family = font, margin = margin(b = 10)),
    plot.caption        = element_text(size = 8,  color = "#888888", hjust = 0,
                                       family = font, margin = margin(t = 8)),
    plot.caption.position = "plot",
    plot.margin         = margin(t = 12, r = 15, b = 10, l = 10)
  )

ggsave(paste0(mydir, "\\processed\\images\\monthlycertifiedworkers.png"),
       width = 2400, height = 1600, units = "px", dpi = 200)

